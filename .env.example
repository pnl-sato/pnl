# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# 候補者DB の Notion database ID（salesforce_notion_sync.py で使用）
CANDIDATE_DB_ID=2057d017b6a080fc9e8d000b3b6ab37e

# ─── Salesforce 接続情報 ──────────────────────────────────────────────────────
# salesforce_notion_sync.py で使用
SF_USERNAME=your_username@example.com
SF_PASSWORD=yourpassword
# セキュリティトークン: SF「設定」→「個人設定」→「セキュリティトークンの再発行」
SF_SECURITY_TOKEN=yourtoken
# sandbox の場合は "test"、本番は "login"（デフォルト）
SF_DOMAIN=login

# ─── Salesforce カスタムフィールド名（任意）────────────────────────────────────
# ご自身の SF 組織のカスタムフィールド API 参照名に合わせて変更してください。
# 未設定の場合は下記デフォルト値が使用されます。
# SF 組織にフィールドが存在しない場合は自動スキップされます。
# SF_FIELD_CURRENT_SALARY=Current_Salary__c
# SF_FIELD_DESIRED_SALARY=Desired_Salary__c
# SF_FIELD_JOB_CHANGE_REASON=Job_Change_Reason__c
# SF_FIELD_SIDE_JOB=Side_Job_Desired__c
