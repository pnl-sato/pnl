# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# ── Salesforce ────────────────────────────────────────────────────────────────
# インスタンス URL（末尾スラッシュなし）
SF_INSTANCE_URL=https://poleline.my.salesforce.com

# 管理者ユーザー名
SF_USERNAME=admin@example.com

# パスワード + セキュリティトークンを連結した文字列
# セキュリティトークン: 設定 → 個人情報 → セキュリティトークンのリセット で取得
SF_PASSWORD=MyPassword1234aBcDeFgHiJkLmNoPqRsT
