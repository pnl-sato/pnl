# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# ポジション DB の Notion database ID
# Notion でポジション DB を開いたときの URL から取得
POSITION_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API キー（JD URL スラッグ生成に使用）
# https://console.anthropic.com/settings/keys で取得
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
