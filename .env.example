# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# ─── Google Drive ──────────────────────────────────────────────────────────────
# サービスアカウントの認証JSONは credentials/gdrive_service_account.json に配置
# （このファイルは .gitignore に含まれるため git 管理外）

# 探索起点となるフォルダID
# Google Drive でフォルダを開いた URL の末尾: drive.google.com/drive/folders/{ここ}
GDRIVE_ROOT_FOLDER_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
