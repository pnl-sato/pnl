# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# --- Salesforce MCP (.mcp.json で利用) ---
# Claude Code on the web では Web UI の「環境設定 → シークレット」に
# 同名で登録すること（このファイルに実値は書かない）。
# 認証は Username/Password + Security Token 方式。
SALESFORCE_USERNAME=your_user@example.com
SALESFORCE_PASSWORD=your_password
SALESFORCE_TOKEN=your_security_token
# 本番: https://login.salesforce.com / Sandbox: https://test.salesforce.com
SALESFORCE_INSTANCE_URL=https://login.salesforce.com
#
# ▼ Salesforce MCP に接続できない場合（重要・2026-06 調査結果）
# 症状：Salesforce ツールが「接続できない／connecting のまま」になる。
# 原因：シークレットや認証ではない。.mcp.json は
#   `npx -y @tsmztech/mcp-server-salesforce`
# で起動するが、これは MCP サーバー起動のたびに依存ツリー（100個超）を
# その場でインストールする。Claude Code on the web のコンテナはセッション毎に
# 新規生成され npm キャッシュが空のため、レジストリ取得が遅いと
# インストールが MCP の起動タイムアウトを超え、サーバーが立ち上がりきらない。
#   （実測：コールド=タイムアウト → ウォーム=約1.2秒で起動・15ツール・実クエリ疎通OK）
# 対策：Web UI の「環境設定 → セットアップスクリプト」（コンテナ生成時に1回走る）に
# 次の1行を追加して npm キャッシュを事前に温める。以降 npx は約1秒で起動する。
#   npm install -g @tsmztech/mcp-server-salesforce
# これで .mcp.json は現状（npx -y）のままで接続できる。
# 切り分け手順：(1) SOAP ログインが通れば認証はシロ
#   → 認証情報は Web UI のシークレットを再確認。(2) 通るのに MCP だけ繋がらないなら
#   上記の起動タイムアウトが原因。セットアップスクリプトの事前インストールで解消する。
