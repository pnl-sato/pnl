# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# ── Slack Bot (slack_notion_todo.py) ──────────────────────────────────────────

# Slack Bot Token (xoxb-...)
# Slack App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxxxxxxxxxx

# Slack Signing Secret
# Slack App → Basic Information → App Credentials → Signing Secret
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slack App-Level Token (xapp-...) ※ Socket Mode を使う場合のみ必要
# Slack App → Basic Information → App-Level Tokens → Generate Token (connections:write)
SLACK_APP_TOKEN=xapp-xxxxxxxxxxxxxxxxxxxxx

# Notion ToDo DB の Database ID
NOTION_TODO_DB_ID=2257d017b6a08026867c000bb0969507

# Notion ポジション DB の Database ID
NOTION_POSITION_DB_ID=1fb7d017b6a08052a7c9000b1aa76cda
