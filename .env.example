# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# --- Salesforce MCP (.mcp.json で利用) ---
# Claude Code on the web では Web UI の「環境設定 → シークレット」に
# 同名で登録すること（このファイルに実値は書かない）。
# 認証は Username/Password + Security Token 方式。
SALESFORCE_USERNAME=your_user@example.com
SALESFORCE_PASSWORD=your_password
SALESFORCE_TOKEN=your_security_token
# 本番: https://login.salesforce.com / Sandbox: https://test.salesforce.com
SALESFORCE_INSTANCE_URL=https://login.salesforce.com
