# Notion API トークン
# Notion → Settings → Integrations → Create integration で取得
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxx

# スカウトDB の Notion database ID
# https://www.notion.so/{workspace}/{この部分}?v=... の値
SCOUT_DB_ID=2597d017b6a0808ea499c4ec941d2a96

# ── Gmail → Notion ToDo 同期 ──────────────────────────────────────────────────

# Notion ToDo DB の ID（URLの ?v= より前の部分からダッシュを除いた32文字）
TODO_DB_ID=（Notion の ToDo DB ページ URL から取得してください）

# Google サービスアカウントの JSON キーファイルパス
GMAIL_SERVICE_ACCOUNT_FILE=/path/to/service_account.json

# 処理対象の Gmail アドレス（サービスアカウントが委任されたアカウント）
GMAIL_USER_EMAIL=you@example.com

# 処理対象の Gmail ラベル名（このラベルが付いたメールを ToDo に変換）
GMAIL_LABEL=NotionToDo

# 処理済みメールに付けるラベル名（自動作成される）
GMAIL_DONE_LABEL=NotionToDo/Done

# （任意）Claude API キー — メール本文のサマリ生成に使用
# なければ本文の先頭 300 文字をサマリとして使用
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
