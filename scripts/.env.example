# video_processor.py の設定
# このファイルをコピーして .env として保存し、各値を設定してください
# cp scripts/.env.example scripts/.env

# ─── Gemini API 設定（文字起こし） ──────────────────────────────────────────
# https://aistudio.google.com/app/apikey で取得（無料）
GEMINI_API_KEY=your_gemini_api_key_here

# 使用するモデル（デフォルト: gemini-2.0-flash）
GEMINI_MODEL=gemini-2.0-flash

# ─── YouTube API 設定 ────────────────────────────────────────────────────────
# Google Cloud Console でダウンロードした OAuth クライアントシークレット JSON のパス
# 取得手順: https://console.cloud.google.com/
#   1. プロジェクト作成 → 「YouTube Data API v3」を有効化
#   2. 認証情報 → OAuth 2.0 クライアント ID → 「デスクトップアプリ」で作成
#   3. JSON をダウンロードしてこのパスに配置
YOUTUBE_CLIENT_SECRETS_FILE=~/client_secrets.json

# 認証トークンのキャッシュ先（自動生成、変更不要）
YOUTUBE_TOKEN_FILE=~/.youtube_token.json

# YouTube の公開設定: private（非公開）/ unlisted（限定公開）/ public（公開）
YOUTUBE_PRIVACY=private

# ─── 変換設定 ────────────────────────────────────────────────────────────────
# mp4 圧縮品質 CRF（18=高画質/大きい ↔ 28=低画質/小さい、デフォルト 23）
VIDEO_CRF=23

# m4a 音声ビットレート（NotebookLM の 100MB 制限対策）
# 64k モノラルで約 29 MB/時間 → 3時間の面談でも余裕あり
# 文字起こし品質に影響なし（通話・面談音声は 64k mono で十分）
AUDIO_BITRATE=64k

# 変換ファイルの出力先（空欄 = 元ファイルと同じフォルダ）
OUTPUT_DIR=

# ─── 処理済み管理 ────────────────────────────────────────────────────────────
# 処理済みファイルの記録 JSON（二重処理防止）
PROCESSED_LOG=~/.video_processor_done.json
