# LINE Messaging API
# LINE Developers (https://developers.line.biz/) で取得
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# Anthropic API
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=sk-ant-...

# 月額上限（円）
MONTHLY_BUDGET_YEN=500

# SQLite DB ファイルのパス（デフォルト: カレントディレクトリの usage.db）
DB_PATH=usage.db

# サーバーポート（デフォルト: 8000）
PORT=8000
